# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for JunoOS
#
# HOW TO USE:
#   1. Copy this file to .env.local:  cp .env.example .env.local
#   2. Fill in the real values below
#   3. Never commit .env.local to git (it is already in .gitignore)
#
# WHERE TO FIND THESE VALUES:
#   Supabase dashboard → your project → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# The URL of your Supabase project (found under "Project URL")
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# The public anonymous key for your Supabase project (found under "Project API keys" → anon/public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The service role key — server-side only, never expose to browser
# Required for: document generation test script (scripts/test-document-generation.ts)
# Found under: Supabase dashboard → Settings → API → "service_role" key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Documenso e-signature integration (Stage 6b)
#
# WHERE TO FIND THESE VALUES:
#   Documenso dashboard → Settings → API Keys (for DOCUMENSO_API_KEY)
#   Documenso dashboard → Settings → Webhooks → your webhook → Secret (for DOCUMENSO_WEBHOOK_SECRET)
#   Both values must also be set in Vercel environment variables for production.
# ─────────────────────────────────────────────────────────────────────────────

# API key for server-side Documenso calls (create envelopes, cancel, download)
DOCUMENSO_API_KEY=your_documenso_api_key_here

# Secret registered in the Documenso webhook config — must match exactly.
# Documenso sends this in the X-Documenso-Secret header with every webhook call.
DOCUMENSO_WEBHOOK_SECRET=your_documenso_webhook_secret_here
